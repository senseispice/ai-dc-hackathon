# === LLM Provider ===
LLM_PROVIDER=gemini             # "anthropic", "openai", or "gemini"
LLM_MODEL=gemini-2.0-flash      # gemini-2.0-flash, claude-sonnet-4-20250514, gpt-4o, etc.

# === API Keys ===
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...

# === CrustData ===
CRUSTDATA_API_KEY=...
CRUSTDATA_MOCK=true             # Set to "false" when you have a real API key

# === ChromaDB ===
CHROMA_PERSIST_DIR=./chroma_db

# === App ===
LOG_LEVEL=INFO
