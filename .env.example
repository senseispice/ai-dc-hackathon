# === LLM Provider ===
LLM_PROVIDER=anthropic          # "anthropic" or "openai"
LLM_MODEL=claude-sonnet-4-20250514

# === API Keys ===
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
CRUSTDATA_API_KEY=...

# === CrustData ===
CRUSTDATA_MOCK=true             # Set to "false" when you have a real API key

# === ChromaDB ===
CHROMA_PERSIST_DIR=./chroma_db

# === App ===
LOG_LEVEL=INFO
